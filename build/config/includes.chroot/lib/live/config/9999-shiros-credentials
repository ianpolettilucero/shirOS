#!/bin/sh
# shirOS — credenciales y sudo para la sesión live.
# live-config (Debian) ejecuta todo lo que esté en /lib/live/config/* al boot.
# Este script corre DESPUÉS de los scripts core (0010-debconf, 0030-user-setup,
# etc.) gracias al prefijo 9999, así que el user 'live' ya existe.
#
# Por qué este script existe:
#   - Aunque LightDM tiene autologin configurado (50-shiros-autologin.conf),
#     en failsafe o si el usuario sale a TTY conviene tener credenciales reales.
#   - El default de live-config a veces deja password vacío que LightDM/PAM
#     rechaza (no usa nullok). Le seteamos 'live' explícito para no depender
#     de ese comportamiento.
#   - sudo sin password porque la live no persiste y debe ser usable.

set -e

if ! getent passwd live >/dev/null 2>&1; then
    # live-config todavía no creó al user — nada que hacer.
    exit 0
fi

# Password conocido (la live es efímera, no es secreto)
echo 'live:live' | chpasswd

# Passwordless sudo para el live user
cat > /etc/sudoers.d/shiros-live <<'EOF'
live ALL=(ALL) NOPASSWD: ALL
EOF
chmod 0440 /etc/sudoers.d/shiros-live
