#!/bin/sh
# shirOS — credenciales y permisos para la sesión live.
# live-config (Debian) ejecuta todo lo que esté en /lib/live/config/* al boot.
# El prefijo 9999 garantiza que corra DESPUÉS de 0030-user-setup, así que
# el user 'live' ya existe.
#
# Tres cosas hacemos acá:
#   1. Password conocido ('live') por si el autologin falla y cae al greeter.
#   2. Sudo sin password para que la live sea usable.
#   3. Agregar 'live' al grupo 'nopasswdlogin' — REQUERIDO por
#      /etc/pam.d/lightdm-autologin en Debian. Sin esto, PAM rechaza el
#      autologin silenciosamente y LightDM muestra el greeter como si la
#      config de autologin no existiera. Este es el bug clásico que muerde
#      a cualquier live-build custom.

set -e

if ! getent passwd live >/dev/null 2>&1; then
    # live-config todavía no creó al user — nada que hacer.
    exit 0
fi

# 1. Password conocido (la live es efímera, no es secreto)
echo 'live:live' | chpasswd

# 2. Passwordless sudo
cat > /etc/sudoers.d/shiros-live <<'EOF'
live ALL=(ALL) NOPASSWD: ALL
EOF
chmod 0440 /etc/sudoers.d/shiros-live

# 3. Grupo nopasswdlogin — gate de PAM para lightdm-autologin.
# Lo crea el paquete passwd/lightdm; lo aseguramos por las dudas.
getent group nopasswdlogin >/dev/null 2>&1 || groupadd -r nopasswdlogin
usermod -aG nopasswdlogin live
