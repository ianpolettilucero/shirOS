#!/bin/bash
# shirOS Fleet Metrics — CLI para IT admin.
#
# Privacy-first (decisión 0004): silent por default. Este CLI permite que
# el admin de IT active opt-in monitoring (Prometheus pull o Pushgateway push)
# sin que el usuario final tenga que tocar nada.
#
# Uso:
#   shiros-fleet status
#   shiros-fleet enable-pull [--listen=ADDR:PORT]
#   shiros-fleet enable-push --url=URL [--interval=Xm] [--user=U --password=P]
#   shiros-fleet disable
#   shiros-fleet test

set -euo pipefail

CONFIG_FILE="/etc/shiros/fleet.conf"
NODE_EXPORTER_DROPIN="/etc/systemd/system/prometheus-node-exporter.service.d/shiros.conf"
PUSH_SERVICE="shiros-fleet-push.service"
PUSH_TIMER="shiros-fleet-push.timer"

log()  { printf '\033[1;34m[shiros-fleet]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[shiros-fleet]\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[1;31m[shiros-fleet]\033[0m %s\n' "$*" >&2; exit 1; }

require_root() {
    [ "$(id -u)" -eq 0 ] || die "Necesita sudo."
}

require_node_exporter() {
    command -v prometheus-node-exporter >/dev/null 2>&1 \
        || die "prometheus-node-exporter no instalado. apt install prometheus-node-exporter"
}

# ─────────────────────────────────────────────────────────────
# Subcomandos
# ─────────────────────────────────────────────────────────────

cmd_status() {
    echo "shirOS Fleet Metrics — estado"
    echo

    local mode="disabled"
    if [ -f "${CONFIG_FILE}" ]; then
        mode=$(grep -E '^SHIROS_FLEET_MODE=' "${CONFIG_FILE}" | cut -d= -f2 | tr -d '"' || echo "disabled")
    fi
    echo "  Modo configurado: ${mode}"

    if systemctl is-active --quiet prometheus-node-exporter.service 2>/dev/null; then
        local listen
        listen=$(systemctl show prometheus-node-exporter.service --property=ExecStart 2>/dev/null \
            | grep -oE -- '--web.listen-address=[^ ]+' || echo "(default)")
        echo "  Pull:   active (${listen})"
    elif systemctl is-enabled --quiet prometheus-node-exporter.service 2>/dev/null; then
        echo "  Pull:   enabled but not running"
    else
        echo "  Pull:   inactive"
    fi

    if systemctl is-active --quiet "${PUSH_TIMER}" 2>/dev/null; then
        local next
        next=$(systemctl show "${PUSH_TIMER}" --property=NextElapseUSecRealtime --value 2>/dev/null || true)
        echo "  Push:   active (next: ${next:-?})"
    elif systemctl is-enabled --quiet "${PUSH_TIMER}" 2>/dev/null; then
        echo "  Push:   enabled but not running"
    else
        echo "  Push:   inactive"
    fi

    echo
    echo "Ver: /etc/shiros/fleet.README.md"
}

cmd_enable_pull() {
    require_root
    require_node_exporter

    local listen="127.0.0.1:9100"
    while [ $# -gt 0 ]; do
        case "$1" in
            --listen=*) listen="${1#*=}" ;;
            *) die "Opción desconocida: $1" ;;
        esac
        shift
    done

    log "Habilitando pull (Prometheus scrape) en ${listen}"
    mkdir -p "$(dirname "${NODE_EXPORTER_DROPIN}")"
    cat > "${NODE_EXPORTER_DROPIN}" <<EOF
# Configurado por shiros-fleet enable-pull
[Service]
Environment=
Environment=ARGS=--web.listen-address=${listen}
ExecStart=
ExecStart=/usr/bin/prometheus-node-exporter \$ARGS
EOF
    systemctl daemon-reload
    systemctl unmask prometheus-node-exporter.service 2>/dev/null || true
    systemctl enable --now prometheus-node-exporter.service

    sed -i "s|^SHIROS_FLEET_MODE=.*|SHIROS_FLEET_MODE=pull|" "${CONFIG_FILE}"
    sed -i "s|^SHIROS_FLEET_LISTEN=.*|SHIROS_FLEET_LISTEN=${listen}|" "${CONFIG_FILE}"

    log "OK. Verificá con: curl http://${listen}/metrics"
    if [[ "${listen}" == 0.0.0.0:* ]] || [[ "${listen}" == :* ]]; then
        warn "El listener está expuesto a la red. Asegurate de tener firewall corporativo."
    fi
}

cmd_enable_push() {
    require_root
    require_node_exporter

    local url="" interval="5m" user="" password=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --url=*)      url="${1#*=}" ;;
            --interval=*) interval="${1#*=}" ;;
            --user=*)     user="${1#*=}" ;;
            --password=*) password="${1#*=}" ;;
            *) die "Opción desconocida: $1" ;;
        esac
        shift
    done
    [ -n "${url}" ] || die "Falta --url=URL"

    log "Habilitando push hacia ${url} cada ${interval}"
    sed -i "s|^SHIROS_FLEET_MODE=.*|SHIROS_FLEET_MODE=push|"            "${CONFIG_FILE}"
    sed -i "s|^SHIROS_FLEET_PUSH_URL=.*|SHIROS_FLEET_PUSH_URL=${url}|"  "${CONFIG_FILE}"
    sed -i "s|^SHIROS_FLEET_PUSH_INTERVAL=.*|SHIROS_FLEET_PUSH_INTERVAL=${interval}|" "${CONFIG_FILE}"
    sed -i "s|^SHIROS_FLEET_PUSH_USER=.*|SHIROS_FLEET_PUSH_USER=${user}|"             "${CONFIG_FILE}"
    sed -i "s|^SHIROS_FLEET_PUSH_PASSWORD=.*|SHIROS_FLEET_PUSH_PASSWORD=${password}|" "${CONFIG_FILE}"

    # Override OnUnitActiveSec del timer al intervalo pedido
    mkdir -p "/etc/systemd/system/${PUSH_TIMER}.d"
    cat > "/etc/systemd/system/${PUSH_TIMER}.d/shiros.conf" <<EOF
[Timer]
OnUnitActiveSec=
OnUnitActiveSec=${interval}
EOF

    systemctl daemon-reload
    systemctl unmask "${PUSH_SERVICE}" "${PUSH_TIMER}" 2>/dev/null || true
    systemctl enable --now "${PUSH_TIMER}"

    log "OK. Próximo push en ${interval}. Logs: journalctl -u ${PUSH_SERVICE}"
}

cmd_disable() {
    require_root
    log "Apagando fleet metrics"
    systemctl disable --now prometheus-node-exporter.service 2>/dev/null || true
    systemctl mask prometheus-node-exporter.service 2>/dev/null || true
    systemctl disable --now "${PUSH_TIMER}" 2>/dev/null || true
    systemctl mask "${PUSH_TIMER}" 2>/dev/null || true
    rm -f "${NODE_EXPORTER_DROPIN}"
    rm -f "/etc/systemd/system/${PUSH_TIMER}.d/shiros.conf"
    systemctl daemon-reload
    sed -i "s|^SHIROS_FLEET_MODE=.*|SHIROS_FLEET_MODE=disabled|" "${CONFIG_FILE}" 2>/dev/null || true
    log "OK. shirOS volvió a silent by default."
}

cmd_test() {
    require_node_exporter
    log "Generando métricas (sin habilitar nada)..."
    /usr/bin/prometheus-node-exporter --web.listen-address=127.0.0.1:0 --log.level=error &
    local pid=$!
    sleep 1
    # Intentar curl al puerto que asignó
    local port
    port=$(ss -tlnp 2>/dev/null | grep -- "pid=${pid}" | awk '{print $4}' | sed -E 's/.*://' | head -1)
    if [ -n "${port}" ]; then
        curl -fsS "http://127.0.0.1:${port}/metrics" | head -40
    else
        warn "no se pudo enganchar el puerto de test."
    fi
    kill ${pid} 2>/dev/null || true
}

# ─────────────────────────────────────────────────────────────
# Dispatch
# ─────────────────────────────────────────────────────────────

case "${1:-status}" in
    status)       shift; cmd_status "$@" ;;
    enable-pull)  shift; cmd_enable_pull "$@" ;;
    enable-push)  shift; cmd_enable_push "$@" ;;
    disable)      shift; cmd_disable "$@" ;;
    test)         shift; cmd_test "$@" ;;
    -h|--help)
        cat <<'EOF'
shiros-fleet — IT admin tool for opt-in fleet metrics.

  status                                          ver estado actual
  enable-pull [--listen=ADDR:PORT]                Prometheus scrape mode
  enable-push --url=URL [--interval=Xm]           Pushgateway mode
                [--user=U --password=P]
  disable                                         apaga todo
  test                                            preview de métricas

Ver: /etc/shiros/fleet.README.md
EOF
        ;;
    *) die "Subcomando desconocido: $1. Probá 'shiros-fleet --help'." ;;
esac
