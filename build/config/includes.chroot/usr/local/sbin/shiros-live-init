#!/bin/sh
# shirOS — inicialización de la sesión live.
# Corre vía shiros-live-init.service (After=live-config, Before=lightdm),
# solo cuando boot=live está en kernel cmdline.
#
# Idempotente: se puede correr múltiples veces sin romper nada.

set -e

LOG=/var/log/shiros-live-init.log
exec >>"${LOG}" 2>&1
echo "=== $(date -Iseconds) shiros-live-init start ==="

if ! getent passwd live >/dev/null 2>&1; then
    echo "I: user 'live' aún no existe — saliendo (debería crearlo live-config primero)"
    exit 0
fi

# 1. Password conocido para fallback si autologin falla
echo 'live:live' | chpasswd
echo "I: password de 'live' seteado a 'live'"

# 2. Passwordless sudo (necesario para Calamares)
cat > /etc/sudoers.d/shiros-live <<'EOF'
live ALL=(ALL) NOPASSWD: ALL
EOF
chmod 0440 /etc/sudoers.d/shiros-live
echo "I: sudoers escrito"

# 3. Grupo nopasswdlogin (gate de PAM para lightdm-autologin)
if ! getent group nopasswdlogin >/dev/null 2>&1; then
    groupadd -r nopasswdlogin
    echo "I: grupo nopasswdlogin creado"
fi
usermod -aG nopasswdlogin live
echo "I: 'live' agregado a nopasswdlogin"

# 4. LightDM autologin — escribimos la config en runtime para que NO se
#    aplique al sistema instalado (donde el user 'live' no existe).
mkdir -p /etc/lightdm/lightdm.conf.d
cat > /etc/lightdm/lightdm.conf.d/50-shiros-autologin.conf <<'EOF'
[Seat:*]
autologin-user=live
autologin-user-timeout=0
autologin-session=xfce
user-session=xfce
greeter-hide-users=false
EOF
echo "I: LightDM autologin snippet escrito"

# 5. Fallback de hostname — live-config en trixie a veces agrega "-live".
if [ "$(hostname)" != "shiros" ]; then
    echo "shiros" > /etc/hostname
    hostname shiros
    echo "I: hostname forzado a 'shiros'"
fi

# Marker para verificar post-boot que esto corrió
touch /var/run/shiros-live-init.done
echo "=== $(date -Iseconds) shiros-live-init OK ==="
