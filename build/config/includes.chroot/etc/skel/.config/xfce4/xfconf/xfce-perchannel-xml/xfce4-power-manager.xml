<?xml version="1.0" encoding="UTF-8"?>

<channel name="xfce4-power-manager" version="1.0">
  <property name="xfce4-power-manager" type="empty">
    <!-- Mostrar siempre el ícono de power/batería en el tray, no solo
         cuando está en batería. Default es 0 (oculto en AC), forzamos
         a 1 (siempre visible). -->
    <property name="show-tray-icon" type="uint" value="1"/>
    <property name="presentation-mode" type="bool" value="false"/>
    <property name="show-panel-label" type="uint" value="0"/>
  </property>
</channel>
