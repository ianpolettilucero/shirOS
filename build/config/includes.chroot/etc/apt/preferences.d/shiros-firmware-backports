# shirOS — pin de kernel + firmware desde bookworm-backports.
#
# El install efectivo lo hace el hook 0001-install-backports-kernel.hook.chroot
# vía `apt-get install -t bookworm-backports`. Este pin es defense in
# depth: si el user después instala/upgrade algún firmware o kernel
# package, apt prefiere la versión de backports.
#
# Usamos `n=` (codename) en vez de `a=` (archive) porque es más
# universalmente parseado por apt en distintas versiones.

# Default para todo lo que esté en backports: priority 100 (instalable
# pero no preferido sobre stable).
Package: *
Pin: release n=bookworm-backports
Pin-Priority: 100

# Kernel y firmware específicos: priority 990 (preferir backports).
# Estos son los packages donde QUEREMOS la versión más nueva sí o sí.
Package: linux-image-amd64 linux-headers-amd64 linux-image-*-amd64 linux-headers-*-amd64 linux-kbuild-* linux-compiler-* firmware-iwlwifi firmware-iwlwifi-* firmware-realtek firmware-realtek-* firmware-atheros firmware-brcm80211 firmware-libertas firmware-misc-nonfree firmware-ralink firmware-zd1211 firmware-linux firmware-linux-nonfree firmware-sof-signed firmware-amd-graphics intel-microcode amd64-microcode
Pin: release n=bookworm-backports
Pin-Priority: 990
