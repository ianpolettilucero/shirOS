# live-build output
build/auto/.lb
build/.build/
build/binary/
build/cache/
build/chroot/
build/config/binary
build/config/bootstrap
build/config/build
build/config/chroot
build/config/common
build/config/source
build/local/
build/*.iso
build/*.img
build/*.log
build/*.contents
build/*.files
build/*.list
build/*.packages
build/*.packages.live
build/binary.hybrid.iso.zsync
build/source.debian.tar.*
build/source.iso

# ISOs at root
*.iso
*.iso.sig
*.iso.sha256

# Editor / OS junk
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/

# Generated assets
branding/**/*.png.cache
branding/plymouth/shiros/*.script.compiled

# Version files — generados por scripts/build-iso.sh en cada build
# desde SHIROS_VERSION. NO commitearlos: si están en git con un valor
# fijo, el ISO va a mentir su versión cuando hagamos bump.
build/config/includes.chroot/etc/os-release
build/config/includes.chroot/etc/lsb-release
build/config/includes.chroot/etc/issue
build/config/includes.chroot/etc/issue.net

# Python (if scripts use venvs)
__pycache__/
*.pyc
.venv/
venv/

# QEMU test artifacts
*.qcow2
test-disk.img

# Local .debs (downloaded by fetch-rustdesk-deb.sh, etc.)
# Each build pulls fresh binaries — no commitearlos.
build/config/packages.chroot/*.deb
